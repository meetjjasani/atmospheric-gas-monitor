# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.idea/
.DS_Store

# ── AI tools ──────────────────────────────────────────────────────────────────
.claude/

# ── Raw sensor data (proprietary, not committed) ───────────────────────────────
data/raw/*
!data/raw/.gitkeep

# ── Generated pipeline outputs (recreated by running prl-pipeline) ────────────
data/processed/*
!data/processed/.gitkeep

data/exports/*
!data/exports/.gitkeep

logs/

# ── Test fixtures data (confidential sensor data) ─────────────────────────────
tests/fixtures/sample_data/*
!tests/fixtures/sample_data/.gitkeep

# ── Build artifacts ────────────────────────────────────────────────────────────
dist/
build/

# ── All data file types ────────────────────────────────────────────────────────
*.dat
*.parquet
*.png
*.csv
